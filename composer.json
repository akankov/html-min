{
  "name": "akankov/html-min",
  "description": "HTML Compressor and Minifier (maintained fork of voku/HtmlMin)",
  "keywords": [
    "html",
    "compress",
    "compression",
    "minify",
    "minifier"
  ],
  "type": "library",
  "homepage": "https://github.com/akankov/html-min",
  "license": "MIT",
  "authors": [
    {
      "name": "Alex Kankov",
      "email": "akankov@gmail.com",
      "role": "Maintainer"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.65",
    "phan/phan": "^6.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.0",
    "rector/rector": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Akankov\\HtmlMin\\": "src/HtmlMin/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Akankov\\HtmlMin\\Tests\\": "tests/"
    }
  },
  "config": {
    "platform": {
      "php": "8.3"
    },
    "sort-packages": true
  },
  "extra": {
    "branch-alias": {
      "dev-rebrand/v1": "1.0.x-dev"
    }
  }
}
